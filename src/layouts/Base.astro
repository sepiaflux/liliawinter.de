---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Lilia Winter — Video, Foto, Installation",
  description = "Eine driftende Sammlung von Video- und Fotoarbeiten zwischen Beobachtung und Auflösung. Berlin, seit 2019.",
  ogImage = "/portfolio/ghostworld-zoe/cover.jpg",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://liliawinter.de").toString();
const ogImageAbs = new URL(ogImage, Astro.site ?? "https://liliawinter.de").toString();
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#edcdd1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="de_DE" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Space+Grotesk:wght@300..700&family=JetBrains+Mono:wght@300..600&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #edcdd1;
        --ink: #0b0b0b;
        --muted: #6b6760;
        --accent: #c44a2c;
        --serif: "Instrument Serif", "Times New Roman", serif;
        --fraunces: "Fraunces", "Times New Roman", serif;
        --sans: "Space Grotesk", system-ui, sans-serif;
        --mono: "JetBrains Mono", ui-monospace, monospace;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--sans);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overscroll-behavior: none;
      }
      html, body { min-height: 100%; }
      body { overflow-x: hidden; }
      a { color: inherit; }
      img { display: block; max-width: 100%; }
      ::selection { background: var(--ink); color: var(--bg); }

      /* Respect reduced motion globally for any CSS animation/transition */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
        }
      }

      /* Soap-bubble keyframes */
      @keyframes bubble-spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
      }
      @keyframes bubble-wobble {
        0%, 100% { transform: scale(1, 1);           border-radius: 50%; }
        25%      { transform: scale(1.015, 0.985);   border-radius: 49% 51% 51% 49% / 51% 49% 49% 51%; }
        50%      { transform: scale(0.985, 1.015);   border-radius: 52% 48% 49% 51% / 48% 52% 51% 49%; }
        75%      { transform: scale(1.01, 0.99);     border-radius: 51% 49% 52% 48% / 49% 51% 48% 52%; }
      }
      /* Real soap-bubble pop: brief stretch, then INSTANT disappear at ~87%.
         No fade — the film snaps and is gone in a single frame. */
      @keyframes bubble-pop {
        0%   { transform: scale(1);    opacity: 1; }
        70%  { transform: scale(1.14); opacity: 1; }
        86%  { transform: scale(1.22); opacity: 1; }
        87%  { transform: scale(1.24); opacity: 0; }
        100% { transform: scale(1.24); opacity: 0; }
      }
      /* Droplets emerge from where they're rendered (anchored at the rim)
         and fly outward + slight gravity. They start invisible and pop in
         right as the film snaps. */
      @keyframes droplet-fly {
        0%   { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
        100% { transform: translate(calc(-50% + var(--dx, 0px)), calc(-50% + var(--dy, 0px))) scale(0.4); opacity: 0; }
      }
      @keyframes pop-shockwave {
        0%   { transform: scale(0.6); opacity: 1; }
        40%  { opacity: 0.7; }
        100% { transform: scale(2.4); opacity: 0; }
      }
      @keyframes pop-flash {
        0%   { transform: scale(0.4); opacity: 0.95; }
        100% { transform: scale(2.1); opacity: 0; }
      }
      @keyframes loading-pulse {
        0%, 100% { opacity: 0.35; }
        50%      { opacity: 1; }
      }
      .scrollbar-hide::-webkit-scrollbar { display: none; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
