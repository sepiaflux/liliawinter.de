---
interface Props {
  title?: string;
}
const { title = "Lilia Winter — Vibecheck" } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..900,0..100;1,9..144,300..900,0..100&family=Space+Grotesk:wght@300..700&family=JetBrains+Mono:wght@100..800&family=Syne:wght@400..800&family=Tangerine:wght@400;700&family=Italianno&family=Pinyon+Script&family=Birthstone&family=Caveat:wght@400..700&family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=DM+Serif+Display:ital@0;1&family=Petit+Formal+Script&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #f3f1ec;
        --ink: #0b0b0b;
        --muted: #6b6760;
        --accent: #c44a2c;
        --serif: "Instrument Serif", "Times New Roman", serif;
        --fraunces: "Fraunces", "Times New Roman", serif;
        --sans: "Space Grotesk", system-ui, sans-serif;
        --mono: "JetBrains Mono", ui-monospace, monospace;
        --display: "Syne", "Space Grotesk", sans-serif;
        --fairy: "Tangerine", "Italianno", "Pinyon Script", cursive;
        --script: "Italianno", "Tangerine", cursive;
        --hand: "Caveat", "Tangerine", cursive;
        --ornament: "Birthstone", "Italianno", cursive;
        --cormorant: "Cormorant Garamond", "Times New Roman", serif;
        --dm-serif: "DM Serif Display", "Times New Roman", serif;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--sans);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overscroll-behavior: none;
      }
      a { color: inherit; }
      img { display: block; max-width: 100%; }
      ::selection { background: var(--ink); color: var(--bg); }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
